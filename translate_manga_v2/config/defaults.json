{
  "paths": {
    "input_dir": "",
    "output_dir": "",
    "workspace_root": "",
    "cache_root": "",
    "saber_root": "vendor/Saber-Translator",
    "saber_python": ""
  },
  "translation": {
    "model": "mimo-v2.5-pro",
    "base_url": "https://your-openai-compatible-base-url/v1",
    "api_key": "",
    "request_timeout_seconds": 90.0,
    "curl_timeout_seconds": 95
  },
  "ocr": {
    "source_language": "japanese",
    "engine": "48px_ocr",
    "enable_hybrid": true,
    "secondary_engine": "manga_ocr",
    "hybrid_threshold": 0.2,
    "fallback_to_manga_ocr_when_48px_unavailable": true
  },
  "prompts": {
    "translation": {
      "system": "你是专业漫画翻译器。\n\n任务是把漫画中的日文文本翻译成自然、准确、紧凑的简体中文。\n\n硬性要求:\n- 逐条处理输入文本, 严格保留 `<|数字|>` 编号前缀\n- 只输出译文, 不要解释, 不要加注释\n- 人名、称呼、语气前后一致\n- 拟声词、音效词、已经是中文的内容可原样保留\n- 尽量少用中文全角标点, 优先使用更紧凑的半角标点\n- 半角标点要自然, 不要影响阅读\n",
      "rounds": {
        "draft": "第1轮 初稿: 忠实翻译, 先保证信息完整和语义正确。",
        "contextual": "第2轮 上下文修订: 结合已给出的上下文和第1轮草稿, 统一称呼、语气和前后逻辑。",
        "final": "第3轮 气泡定稿: 不改变含义, 压缩成更适合漫画气泡的自然中文, 少标点, 更顺眼。"
      },
      "profiles": {
        "english": {
          "system": "你是专业漫画翻译器。\n\n任务是把漫画中的英文文本翻译成自然、准确、紧凑的简体中文。\n\n硬性要求:\n- 逐条处理输入文本, 严格保留 `<|数字|>` 编号前缀\n- 只输出译文, 不要解释, 不要加注释\n- 人名、称呼、语气前后一致\n- 拟声词、音效词、已经是中文的内容可原样保留\n- 尽量少用中文全角标点, 优先使用更紧凑的半角标点\n- OCR 可能把 O/0、I/1/l、E/F、字母重复或撇号识别错; 结合英文上下文纠正明显 OCR 噪声, 不要机械照抄错字\n",
          "rounds": {
            "draft": "第1轮 初稿: 忠实翻译英文原意, 先修正明显 OCR 噪声并保证信息完整。",
            "contextual": "第2轮 上下文修订: 结合上下文和第1轮草稿, 统一称呼、语气和前后逻辑。",
            "final": "第3轮 气泡定稿: 不改变含义, 压缩成适合欧美漫画横排气泡的自然中文, 少标点, 更顺眼。"
          }
        }
      }
    }
  },
  "pipeline": {
    "overwrite_existing": false,
    "debug_output": true,
    "debug_flush_interval": 25,
    "color_fast_mode": true,
    "translation_quality": "high",
    "skip_frontmatter": true,
    "translate_batch_size": 3,
    "translate_batch_max_chars": 1600,
    "manga_context_file_names": [
      "manga_context.md",
      "manga_context.txt"
    ],
    "auto_generate_manga_context": true
  },
  "inpaint": {
    "method": "solid",
    "mask_dilate_size": 1,
    "mask_box_expand_ratio": 0
  },
  "render": {
    "font_family": "fonts/思源黑体SourceHanSansK-Bold.TTF",
    "layout_mode": "vertical",
    "stroke_enabled": true,
    "stroke_color": "#FFFFFF",
    "stroke_width": 1,
    "line_spacing": 0.84,
    "text_align": "center",
    "vertical_layout": {
      "font_family": "fonts/汉仪正圆-65W.TTF",
      "line_spacing": 1.04,
      "auto_font": {
        "min_size": 14,
        "max_size": 60,
        "padding_ratio": 0.86
      }
    },
    "watermark": {
      "enabled": true,
      "text": "HUGO2233汉化",
      "fill_color": "#A8A8A8",
      "fill_alpha": 176,
      "stroke_color": "#FFFFFF",
      "stroke_alpha": 224,
      "stroke_width": 1,
      "font_size_ratio": 0.014,
      "min_size": 10,
      "max_size": 18,
      "margin_ratio": 0.015
    },
    "auto_font": {
      "min_size": 16,
      "max_size": 72,
      "padding_ratio": 0.96
    }
  },
  "runtime": {
    "saber_session_timeout_seconds": 45.0,
    "saber_subprocess_timeout_seconds": 45.0,
    "saber_operation_timeout_seconds": {
      "preprocess": 180.0
    }
  }
}
